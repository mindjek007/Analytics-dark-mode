{
  "manifest_version": 3,
  "name": "Analytics dark mode",
  "version": "1.1.0",
  "description": "Google Analytics Dark Mode — Multiple color schemes",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Analytics Dark Mode — Change color scheme",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "css": ["src/analytics.css"],
      "js": ["src/content.js"],
      "matches": ["https://analytics.google.com/*"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["https://analytics.google.com/"]
}
